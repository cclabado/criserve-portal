APP_NAME=CrIServe
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.example

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=criserve
DB_USERNAME=criserve
DB_PASSWORD=change-me

CACHE_STORE=redis
CACHE_PREFIX=criserve-production

SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_STORE=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=180

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default

FILESYSTEM_DISK=s3
SECURE_DOCUMENT_DISK=s3
WORKFLOW_UPLOAD_DISK=s3
PAYOUT_PROOF_DISK=s3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=criserve-production
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=
AWS_ENDPOINT=

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=no-reply@your-domain.example
MAIL_FROM_NAME="CrIServe"

DOCUMENT_SCAN_ENABLED=true
DOCUMENT_SCAN_MODE=quarantine
DOCUMENT_SCAN_QUEUE=documents
DOCUMENT_SCAN_COMMAND="/usr/bin/clamscan --no-summary {file}"

AUDIT_LOG_MODE=queue
AUDIT_LOG_QUEUE=audit

MFA_DEFAULT_CODE=
